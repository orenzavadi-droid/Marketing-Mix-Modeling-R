data <- read.csv("Advertising.csv")
library(tidyverse)
library(corrplot)
# 1. Load Required Libraries
# If you don't have these installed, run: install.packages(c("tidyverse", "corrplot"))
library(tidyverse)
library(corrplot)
setwd("C:/Users/orenz/OneDrive/שולחן העבודה/DATA ANALYSYS STUFF/Marketing-Mix-Modeling-R/database")
# 3. Load the Dataset
data <- read.csv("Advertising.csv")
# 4. Initial Data Inspection
print("--- Dataset Dimensions ---")
print(dim(data))
print("--- First Few Rows ---")
print(head(data))
print("--- Summary Statistics ---")
print(summary(data))
# 1. Drop the unnecessary 'X' column
data_clean <- data %>% select(-X)
# 2. Calculate the Correlation Matrix
cor_matrix <- cor(data_clean)
print("--- Correlation Matrix ---")
print(cor_matrix)
# 3. Plot an awesome correlation heatmap
corrplot(cor_matrix, method = "color", addCoef.col = "black",
tl.col = "black", tl.srt = 45,
col = colorRampPalette(c("#E46464", "#FFFFFF", "#4B9CD3"))(200),
title = "\n\nMarketing Channels Correlation with Sales",
mar = c(0,0,1,0))
# 1. Train the Multiple Linear Regression Model
model <- lm(Sales ~ TV + Radio + Newspaper, data = data_clean)
# 2. Print the Model Summary (This is where the magic happens)
print("--- Regression Model Summary ---")
summary(model)
# 1. Generate predictions using our trained model
data_clean$Predicted_Sales <- predict(model, newdata = data_clean)
# 2. Plot Actual vs. Predicted Sales using ggplot2
ggplot(data_clean, aes(x = Sales, y = Predicted_Sales)) +
geom_point(color = "#4B9CD3", alpha = 0.7, size = 2) +
geom_abline(intercept = 0, slope = 1, color = "#E46464", linetype = "dashed", size = 1) +
labs(
title = "Model Evaluation: Actual vs. Predicted Sales",
subtitle = paste("Multiple R-squared:", round(summary(model)$r.squared, 4)),
x = "Actual Sales (Thousands of Units)",
y = "Predicted Sales (Thousands of Units)"
) +
theme_minimal(base_size = 13) +
theme(
plot.title = element_text(face = "bold", hjust = 0.5),
plot.subtitle = element_text(hjust = 0.5, color = "gray30")
